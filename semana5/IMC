peso = float(input("Peso(en KG): "))
altura = float(input("Altura(en Metros): "))
imc = peso / (altura ** 2)

if imc < 18.5:
    print("Bajo peso")
elif imc <= 24.9:
    print("Normal")
elif imc <= 29.9:
    print("Sobrepeso")
else:
    print("Obesidad")
