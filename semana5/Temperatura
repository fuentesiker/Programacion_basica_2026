temp = int(input("Temperatura: "))
if temp < 5:
    print("MUY FRÍO")
elif temp <= 14:
    print("FRÍO")
elif temp <= 24:
    print("TEMPLADO")
elif temp <= 34:
    print("CALIENTE")
else:
    print("MUY CALIENTE")


